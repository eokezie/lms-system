# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# MongoDB — external connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lms?retryWrites=true&w=majority

# Redis — used by BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (future use)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@lms.dev

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Google Keys
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Keys
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Backend base URL for OAuth callback
BACKEND_BASE_URL=http://localhost:3000

# Frontend URL to redirect to after OAuth 
FRONTEND_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Resend (Test email provider till client shared there email provider)
RESEND_API_KEY=
RESEND_MAILER_SENDER=
