{
	"name": "lms-backend",
	"version": "1.0.0",
	"description": "LMS Backend - Distributed Monolith",
	"main": "dist/server.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsx watch src/server.ts",
		"start": "node server.js",
		"start:api": "node server.js",
		"start:worker": "node dist/workers.js",
		"test": "jest --runInBand --forceExit",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage --runInBand --forceExit",
		"lint": "eslint src --ext .ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@mux/mux-node": "^12.8.1",
		"aws-sdk": "^2.1693.0",
		"bcryptjs": "^2.4.3",
		"bullmq": "^5.4.2",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"express-rate-limit": "^7.2.0",
		"helmet": "^7.1.0",
		"ioredis": "^5.3.2",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.3.1",
		"multer": "^2.1.1",
		"nodemailer": "^8.0.1",
		"passport": "^0.7.0",
		"passport-facebook": "^3.0.0",
		"passport-google-oauth20": "^2.0.0",
		"pino": "^9.2.0",
		"pino-http": "^10.2.0",
		"resend": "^6.9.2",
		"zod": "^3.23.4"
	},
	"devDependencies": {
		"@faker-js/faker": "^8.4.1",
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.12",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/multer": "^2.1.0",
		"@types/node": "^20.12.7",
		"@types/nodemailer": "^7.0.10",
		"@types/passport": "^1.0.17",
		"@types/passport-facebook": "^3.0.4",
		"@types/passport-google-oauth20": "^2.0.17",
		"@types/supertest": "^6.0.2",
		"@typescript-eslint/eslint-plugin": "^7.7.1",
		"@typescript-eslint/parser": "^7.7.1",
		"eslint": "^8.57.0",
		"jest": "^29.7.0",
		"mongodb-memory-server": "^9.2.0",
		"pino-pretty": "^11.2.1",
		"supertest": "^7.0.0",
		"ts-jest": "^29.1.2",
		"tsx": "^4.8.2",
		"typescript": "^5.4.5"
	}
